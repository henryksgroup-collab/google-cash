{
  "version": 2,
  "functions": {
    "api/*.js": { "maxDuration": 30 }
  },
  "redirects": [],
  "rewrites": [
    { "source": "/",             "destination": "/api/guard" },
    { "source": "/funil",        "destination": "/api/guard" },
    { "source": "/funil.html",   "destination": "/api/guard" },
    { "source": "/api/vapid-key",  "destination": "/api/notify?action=vapid-key" },
    { "source": "/api/subscribe",  "destination": "/api/notify?action=subscribe" },
    { "source": "/api/test-push",  "destination": "/api/notify?action=test" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://google-cash.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,x-admin-token,x-user-token,x-api-key,x-ai-provider" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",             "value": "1; mode=block" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",           "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains" }
      ]
    },
    {
      "source": "/(.*)\\.mp4",
      "headers": [
        { "key": "Content-Type",   "value": "video/mp4" },
        { "key": "Accept-Ranges",  "value": "bytes" },
        { "key": "Cache-Control",  "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ]
}
