{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Lembra clientes, estrategias e contexto entre sessoes"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "mcp-server-fetch"],
      "description": "Verifica sites de clientes e busca dados publicos"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "COLE_SUA_CHAVE_AQUI"
      },
      "description": "Pesquisa web — busca concorrentes e mercado"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Raciocinio avancado passo a passo"
    }
  }
}
